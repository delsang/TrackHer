@model TrackHerWebApp.Models.SubmissionResultViewModel

@{
    ViewData["Title"] = "Today's Colour";
}

<h1>@Model.ConfirmationMessage</h1>

<div style="width: 200px; height: 200px; background-color: @Model.HexColour; border: 1px solid #ccc; margin: 1rem 0;"></div>

<p><strong>@Model.Colour</strong> &mdash; @Model.HexColour</p>

<a asp-action="Index" asp-controller="Home">Go Back</a>
